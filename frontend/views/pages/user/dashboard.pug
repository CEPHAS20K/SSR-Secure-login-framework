extends ../../layouts/base

include ../../components/navbar
include ../../components/button

block content
  +appNavbar(activePage || "dashboard")
  .min-h-dvh.bg-gradient-to-br.from-orange-50.to-rose-100
    .relative.mx-auto.flex.max-w-6xl.flex-col.gap-6.px-4.py-16(class="sm:px-6 lg:px-10")
      // Hero + quick stats
      .flex.flex-col.gap-3(class="sm:flex-row sm:items-start sm:justify-between")
        .space-y-2
          p.text-xs.font-bold.uppercase.tracking-wide.text-rose-700 Secure Vault
          h1.text-4xl.font-black.text-rose-900.font-headline(class="sm:text-5xl") Your encrypted space
          p.text-sm.font-semibold.text-rose-800 Manage encrypted notes, attachments, and usage at a glance.
          .flex.flex-wrap.items-center.gap-2
            span.rounded-full.px-3.py-1.text-xs.font-semibold.uppercase.text-rose-50(
              style="background-color: #7f1d1d"
            ) Version #{ appVersion || "dev" }
            span.rounded-full.bg-white.px-3.py-1.text-xs.font-semibold.text-rose-900.border.border-rose-200.opacity-80 Live
            span.rounded-full.bg-emerald-50.px-3.py-1.text-xs.font-semibold.text-emerald-800.border.border-emerald-200 Encryption: AES-256
        .rounded-2xl.border.border-rose-200.bg-white.p-4.shadow-lg.backdrop-blur.opacity-80
          p.text-xs.font-bold.uppercase.text-rose-700 Quick stats
          .mt-3.grid.grid-cols-2.gap-3
            .rounded-xl.bg-rose-900.p-3.text-rose-50.shadow-inner.opacity-90
              p.font-semibold.uppercase(class="text-[11px]") Used
              p#metricUsed.text-lg.font-black --
            .rounded-xl.bg-white.p-3.text-rose-900.border.border-rose-200.opacity-90
              p.font-semibold.uppercase(class="text-[11px]") Quota
              p#metricQuota.text-lg.font-black --
            .rounded-xl.bg-white.p-3.text-rose-900.border.border-rose-200.opacity-90
              p.font-semibold.uppercase(class="text-[11px]") Items
              p#metricItems.text-lg.font-black —
            .rounded-xl.bg-white.p-3.text-rose-900.border.border-rose-200.opacity-90
              p.font-semibold.uppercase(class="text-[11px]") Attachments
              p#metricAttachments.text-lg.font-black —

      // Storage + links
      .grid.gap-5(class="lg:grid-cols-3")
        .rounded-2xl.border.border-rose-200.bg-white.p-5.shadow-lg.backdrop-blur.opacity-80(
          class="lg:col-span-2"
        )
          h2.text-lg.font-bold.text-rose-900 Vault Storage
          p.mt-1.text-sm.font-semibold.text-rose-800 Vault usage is calculated from encrypted items and attachments.
          .mt-4.flex.items-center.gap-3.flex-wrap
            div
              p.text-xs.font-bold.uppercase.text-rose-700 User ID
              input#userIdInput.w-64.rounded-lg.border.border-rose-200.px-3.py-2.text-sm.font-semibold.text-rose-950.outline-none.bg-white.opacity-80(
                type="text",
                placeholder="paste user UUID",
                class="placeholder:text-rose-300 focus:border-primary focus:ring-2 focus:ring-primary/20"
              )
            +appButton("Save", "primary", "button")#saveUserIdBtn
            +appButton("Refresh usage", "ghost", "button")#refreshUsageBtn
            +appButton("Use demo user", "ghost", "button")#loadDemoUserBtn
            p#usageStatus.text-xs.font-semibold.text-rose-700
          .mt-5
            p.text-sm.font-bold.text-rose-900.flex.items-center.gap-2
              span.h-3.w-3.rounded-full.bg-emerald-500
              | Vault usage
            .mt-2.w-full.rounded-xl.border.border-rose-200.bg-white.p-3.shadow-inner.opacity-80
              .flex.items-center.justify-between.text-xs.font-semibold.text-rose-800
                span Current
                span#vaultUsageSummary 0 B used
              .mt-2.h-3.w-full.rounded-full.bg-rose-100
                #usageBar.h-3.rounded-full.bg-gradient-to-r.from-orange-400.to-rose-600.transition-all.duration-300.ease-out(
                  style="width: 0%"
                )
              p#usageHint.mt-1.font-semibold.text-rose-700(class="text-[11px]") Quota: —
          .mt-6
            p.text-sm.font-bold.text-rose-900.flex.items-center.gap-2
              span.h-3.w-3.rounded-full.bg-sky-500
              | Usage trend (last 7 days)
            .mt-3.w-full.rounded-xl.border.border-rose-100.bg-white.p-3.shadow-inner.opacity-80
              svg#usageTrendChart.h-32.w-full.text-rose-900(
                role="img",
                aria-label="Usage trend chart"
              )
              p#usageTrendHint.mt-2.font-semibold.text-rose-700(class="text-[11px]") Trend shows daily totals (placeholder until real data is connected).
        .rounded-2xl.border.border-rose-200.bg-white.p-5.shadow-lg.backdrop-blur.opacity-80
          h2.text-lg.font-bold.text-rose-900 Quick Links
          .mt-3.flex.flex-col.gap-3
            +appButton("Open Vault API docs", "primary", "button")(
              onclick="window.location.href='/api-docs'"
            )
            +appButton("Back to login", "ghost", "button")(
              onclick="window.location.href='/login'"
            )
            +appButton("Refresh this dashboard", "ghost", "button")(
              onclick="window.location.reload()"
            )
          p.mt-3.text-sm.font-semibold.text-rose-800 This dashboard is user-only and will soon include uploads, sharing, and attachments.

      // Recent items + audit glance
      .grid.gap-5(class="lg:grid-cols-3")
        .rounded-2xl.border.border-rose-200.bg-white.p-5.shadow-lg.backdrop-blur.opacity-80(
          class="lg:col-span-2"
        )
          .flex.items-center.justify-between.gap-2
            h2.text-lg.font-bold.text-rose-900 Recent vault items
            +appButton("New encrypted item", "primary", "button")#ctaNewItem
          p.mt-1.text-sm.font-semibold.text-rose-800 Requires your user ID to load encrypted items. No plaintext is shown here.
          .mt-4.overflow-hidden.rounded-xl.border.border-rose-200.bg-white.opacity-70
            table.w-full.text-sm.font-semibold.text-rose-900
              thead.bg-rose-50.opacity-80
                tr
                  th.px-3.py-2.text-left Title
                  th.px-3.py-2.text-left Scheme
                  th.px-3.py-2.text-right Size
                  th.px-3.py-2.text-right Updated
              tbody#vaultItemsBody
                tr(data-empty)
                  td.px-3.py-3.text-center.text-rose-700(colspan="4") Add a user ID and click refresh usage.
        .rounded-2xl.border.border-rose-200.bg-white.p-5.shadow-lg.backdrop-blur.opacity-80
          h2.text-lg.font-bold.text-rose-900 Audit glance
          p.mt-1.text-sm.font-semibold.text-rose-800 Basic activity cues (client-side only for now).
          ul#auditGlance.mt-3.space-y-2.text-sm.font-semibold.text-rose-900
            li.flex.items-center.gap-2
              span.h-2.w-2.rounded-full.bg-emerald-500
              | Reads tracked when you open an item.
            li.flex.items-center.gap-2
              span.h-2.w-2.rounded-full.bg-orange-500
              | Updates tracked when you replace ciphertext.
            li.flex.items-center.gap-2
              span.h-2.w-2.rounded-full.bg-sky-500
              | Attachments tracked when uploaded.
          p.mt-4.font-semibold.text-rose-700(class="text-[11px]") Full audit history will appear once server APIs are wired.

      // Roadmap / compliance
      .rounded-2xl.border.border-rose-200.bg-white.p-5.shadow-lg.backdrop-blur.opacity-80
        h2.text-lg.font-bold.text-rose-900 What’s next
        .grid.gap-4(class="md:grid-cols-2")
          .space-y-2
            p.text-xs.font-bold.uppercase.text-rose-700 Features
            ul.list-disc.pl-4.text-sm.font-semibold.text-rose-900
              li READ / WRITE / DOWNLOAD sharing tokens with expiry
              li Versioning with restore and PDF inline preview
              li Watermarked shares for PDF exports
              li Per-user storage quotas and audits
          .space-y-2
            p.text-xs.font-bold.uppercase.text-rose-700 Security & Performance
            ul.list-disc.pl-4.text-sm.font-semibold.text-rose-900
              li HTTPS + HSTS + CSP + rate limits
              li CSRF + XSS sanitization guardrails
              li Async uploads and background encryption
              li Cached metadata queries for speed

  script(src=assetPath("/js/pages/dashboard.js"), type="module")
