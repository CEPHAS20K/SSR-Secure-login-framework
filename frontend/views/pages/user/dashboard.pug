extends ../../layouts/base

include ../../components/navbar
include ../../components/button

block content
  +appNavbar(activePage || "dashboard")
  .min-h-dvh.bg-gradient-to-br.from-orange-50.to-rose-100
    .relative.mx-auto.flex.max-w-5xl.flex-col.gap-6.px-4.py-16.sm.lg:px-6:px-10
      .flex.items-center.justify-between.gap-3
        h1.text-4xl.font-black.text-rose-900.font-headline Tracking your secure vault
        span.rounded-full.bg-rose-900/90.px-3.py-1.text-xs.font-semibold.uppercase.text-rose-50 Version #{appVersion || "dev"}

      .grid.gap-5.md:grid-cols-2
        .rounded-2xl.border border-rose-200/70.bg-white/80.p-5.shadow-lg.backdrop-blur
          h2.text-lg.font-bold.text-rose-900 Vault Status
          p.mt-2.text-sm.font-semibold.text-rose-800 You are signed in. Upload encrypted secrets, documents, and attachments from the upcoming vault UI.
          ul.mt-3.space-y-1.text-sm.font-semibold.text-rose-900
            li.flex.items-center.gap-2
              span.h-2.w-2.rounded-full.bg-emerald-500
              | Storage quota per user: 10 GB (configurable)
            li.flex.items-center.gap-2
              span.h-2.w-2.rounded-full.bg-sky-500
              | Attachments are encrypted and counted toward your quota.
            li.flex.items-center.gap-2
              span.h-2.w-2.rounded-full.bg-amber-500
              | Audit trails capture reads, writes, and attachments.
        .rounded-2xl.border border-rose-200/70.bg-white/80.p-5.shadow-lg.backdrop-blur
          h2.text-lg.font-bold.text-rose-900 Quick Actions
          .mt-3.flex.flex-wrap.items-center.gap-3
            +appButton("Go to Vault API docs", "primary", "button")(onclick="window.location.href='/api-docs'")
            +appButton("View Admin Dashboard", "ghost", "button")(onclick="window.location.href='/admin/dashboard'")
          p.mt-3.text-sm.font-semibold.text-rose-800 The full user vault UI is coming next. Upload endpoints are live for client integrations.

      .rounded-2xl.border border-rose-200/70.bg-white/80.p-5.shadow-lg.backdrop-blur
        h2.text-lg.font-bold.text-rose-900 What’s next
        ul.mt-3.grid.list-disc.gap-2.pl-4.text-sm.font-semibold.text-rose-900.sm:grid-cols-2
          li End-to-end encrypted vault UI with upload progress
          li Per-user storage graph and quota warnings
          li Attachment download with audit trails
          li Shared secret exchange with expiring links
  script(src=assetPath("/js/pages/dashboard.js"), type="module")
