mixin appNavbar(activePage)
  - const isAdminNav = String(activePage || "").startsWith("admin");
  - const isUserDashboard = String(activePage || "") === "dashboard";
  - const showHome = isAdminNav ? true : !isUserDashboard && activePage !== "landing";
  - const showLogin = isAdminNav ? false : !isUserDashboard && activePage !== "login";
  - const showRegister = isAdminNav ? false : !isUserDashboard && activePage !== "register";
  nav#appNavbar.fixed.inset-x-0.top-0.z-40.px-3.py-3(class="sm:px-4 sm:py-4")
    .mx-auto.w-full.max-w-5xl.rounded-2xl.px-3.backdrop-blur-xl.border-transparent.bg-transparent(
      class="py-2.5 sm:px-4 md:px-6"
    )
      .flex.items-center.justify-between(data-nav-shell="true")
        a.uppercase.tracking-wider.text-rose-950.font-display.text-base.font-bold(
          href="/",
          class="sm:text-xl",
          data-nav-transition="auth",
          style="font-family: 'Schoolbell', cursive"
        )
          span.hidden(class="sm:inline") Secure Storage Vault
          span(class="sm:hidden") SSV
        button#navToggle.flex.h-9.w-9.items-center.justify-center.rounded-lg.border.transition.text-rose-900.bg-transparent(
          type="button",
          aria-expanded="false",
          aria-controls="mobileNav",
          class="border-white/25 hover:bg-white/20 sm:hidden"
        )
          span.sr-only Toggle navigation
          span#navToggleBars.flex.flex-col.gap-1
            span.block.w-4.rounded-full.bg-current(class="h-0.5")
            span.block.w-4.rounded-full.bg-current(class="h-0.5")
            span.block.w-4.rounded-full.bg-current(class="h-0.5")
        .hidden.items-center.gap-3(class="sm:flex sm:gap-5")
          if isUserDashboard
            button.rounded-lg.px-3.text-sm.font-bold.transition.text-rose-900(
              type="button",
              onclick="window.location.reload()",
              class="py-1.5 bg-white/20 hover:bg-primary hover:text-white"
            ) Refresh
            button.rounded-lg.px-3.text-sm.font-bold.transition.bg-primary.text-white(
              type="button",
              data-logout="true",
              class="py-1.5 hover:bg-secondary hover:text-amber-50"
            ) Logout
            .flex.items-center.gap-2.pl-2
              span#navUserAvatar.flex.h-8.w-8.items-center.justify-center.rounded-full.bg-gradient-to-br.from-rose-500.to-orange-400.text-xs.font-black.text-rose-50.uppercase U
              span#navUserLabel.text-sm.font-bold.text-rose-900 User
          if showHome
            a.rounded-lg.px-3.text-sm.font-bold.transition.text-rose-900(
              href="/",
              class="py-1.5 bg-white/20 hover:bg-primary hover:text-white sm:text-base",
              data-nav-link="home",
              style="font-family: 'Schoolbell', cursive"
            ) Home
          if showLogin
            a.rounded-lg.px-3.text-sm.font-bold.transition.text-rose-900(
              href="/login",
              class="py-1.5 bg-white/20 hover:bg-primary hover:text-white sm:text-base",
              data-nav-link="login",
              style="font-family: 'Schoolbell', cursive"
            ) Login
          if showRegister
            a.rounded-lg.px-3.text-sm.font-bold.transition.bg-primary.text-white(
              href="/register",
              class="py-1.5 hover:bg-secondary hover:text-amber-50 sm:text-base",
              data-nav-link="register",
              style="font-family: 'Schoolbell', cursive"
            ) Register
      #mobileNav.hidden.border-t.pt-3.mt-3.border-transparent.bg-transparent(class="sm:hidden")
        .grid.gap-2
          if isUserDashboard
            button.rounded-lg.px-3.py-2.text-base.font-bold.transition.text-rose-900(
              type="button",
              class="bg-white/20 hover:bg-primary hover:text-white",
              onclick="window.location.reload()"
            ) Refresh
            button.rounded-lg.px-3.py-2.text-base.font-bold.transition.text-rose-900(
              type="button",
              data-logout="true",
              class="bg-white/20 hover:bg-primary hover:text-white"
            ) Logout
            .flex.items-center.gap-2.px-3.py-2
              span#navUserAvatarMobile.flex.h-9.w-9.items-center.justify-center.rounded-full.bg-gradient-to-br.from-rose-500.to-orange-400.text-sm.font-black.text-rose-50.uppercase U
              span#navUserLabelMobile.text-sm.font-bold.text-rose-900 User
          if showHome
            a.rounded-lg.px-3.py-2.text-base.font-bold.transition.text-rose-900(
              href="/",
              class="bg-white/20 hover:bg-primary hover:text-white",
              data-nav-link="home",
              style="font-family: 'Schoolbell', cursive"
            ) Home
          if showLogin
            a.rounded-lg.px-3.py-2.text-base.font-bold.transition.text-rose-900(
              href="/login",
              class="bg-white/20 hover:bg-primary hover:text-white",
              data-nav-link="login",
              style="font-family: 'Schoolbell', cursive"
            ) Login
          if showRegister
            a.rounded-lg.px-3.py-2.text-base.font-bold.transition.text-rose-900(
              href="/register",
              class="bg-white/20 hover:bg-primary hover:text-white",
              data-nav-link="register",
              style="font-family: 'Schoolbell', cursive"
            ) Register
